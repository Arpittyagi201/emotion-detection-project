PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (DO NOT COMMIT REAL CREDENTIALS)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/depressionDB?retryWrites=true&w=majority

# JWT secret (use a long, random string in real .env)
JWT_SECRET=your_jwt_secret_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Python ML API endpoints
PYTHON_TEXT_API=https://emotion-detection-system-api.onrender.com/emotion_text
PYTHON_VOICE_API=https://emotion-detection-system-api.onrender.com/emotion_voice
PYTHON_IMAGE_API=https://emotion-detection-system-api.onrender.com/emotion_image

